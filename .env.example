PORT=4000

POSTGRES_USER=knowledge_hub
POSTGRES_PASSWORD=knowledge_hub
POSTGRES_DB=knowledge_hub
POSTGRES_HOST=localhost
POSTGRES_PORT=5432

# DATABASE_URL structure:
# postgresql://${POSTGRES_USER}:${POSTGRES_PASSWORD}@${POSTGRES_HOST}:${POSTGRES_PORT}/${POSTGRES_DB}?schema=public&connection_limit=10&pool_timeout=20
DATABASE_URL=postgresql://knowledge_hub:knowledge_hub@localhost:5432/knowledge_hub?schema=public&connection_limit=10&pool_timeout=20

CRYPT_SALT=10
JWT_SECRET_KEY=secret123123
JWT_SECRET_REFRESH_KEY=secret123123
TOKEN_EXPIRE_TIME=1h
TOKEN_REFRESH_EXPIRE_TIME=24h

LOG_LEVEL=log
LOG_MAX_FILE_SIZE=1024

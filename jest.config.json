{
  "projects": [
    {
      "displayName": "e2e",
      "rootDir": "test",
      "moduleFileExtensions": ["ts", "js"],
      "testEnvironment": "node",
      "testMatch": ["<rootDir>/*.spec.ts"],
      "transform": {
        "^.+\\.(t|j)s$": "ts-jest"
      },
      "globalSetup": "<rootDir>/setup/seedAdmin.ts"
    },
    {
      "displayName": "additional",
      "rootDir": ".",
      "moduleFileExtensions": ["ts", "js", "json"],
      "testEnvironment": "node",
      "testRegex": "src/additional-tests/.+\\.spec\\.ts$",
      "transform": {
        "^.+\\.(t|j)s$": "ts-jest"
      }
    }
  ]
}
